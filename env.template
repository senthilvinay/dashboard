# ── CP360° Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# The Flask server loads this automatically via python-dotenv.

# ── Flask Server ───────────────────────────────────────────────────────
PORT=5000
SECRET_KEY=change-me-to-a-random-string

# ── MKS / SSH ─────────────────────────────────────────────────────────
# These are optional — the dashboard prompts the user for credentials.
# Set here if you want the standalone script to run without prompting.
MKS_USER=
MKS_PASSWORD=
MKS_PORT=5001

# ── JAWS Database (FreeTDS) ────────────────────────────────────────────
# Leave blank to run in demo mode (no DB required).
DB_SERVER=NYP_WM_JAWS_SEC_ORCH
DB_NAME=JAWS_SEC_ORCH

# ── ServiceNow ────────────────────────────────────────────────────────
# Leave blank to run in demo mode.
SNOW_INSTANCE=yourcompany.service-now.com
SNOW_USER=api_user
SNOW_PASS=api_password

# ── Teams Webhooks ─────────────────────────────────────────────────────
TEAMS_WEBHOOK_OPS=https://outlook.office.com/webhook/...
TEAMS_WEBHOOK_SRE=https://outlook.office.com/webhook/...
TEAMS_WEBHOOK_MGMT=https://outlook.office.com/webhook/...
TEAMS_WEBHOOK_DEV=https://outlook.office.com/webhook/...

# ── Teams (internal istasgWS for MMNG monitor) ─────────────────────────
TEAMS_CHANNEL=YOUR_TEAMS_CHANNEL_NAME
TEAMS_GRN=grn://ms/Apica

# ── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=msa-hub.ms.com
SMTP_PORT=25

# ── URLs ───────────────────────────────────────────────────────────────
SERVER_URL=http://your-server:5000
DASHBOARD_URL=http://your-server:5000

# ── CSV output folder for MKS restart report ──────────────────────────
CSV_DIR=/var/tmp
